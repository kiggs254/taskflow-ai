# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/taskflow

# API Security
API_SECRET=TASKFLOW_SECRET_KEY_999

# AI Provider API Keys (any subset; unconfigured providers are skipped)
OPENAI_API_KEY=sk-your-openai-api-key-here
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
# Moonshot (Kimi) — the current default primary. OpenAI-compatible.
MOONSHOT_API_KEY=sk-your-moonshot-api-key-here
# Xiaomi MiMo — OpenAI-compatible.
MIMO_API_KEY=your-mimo-api-key-here
# Optional: override the primary provider or any model id.
# AI_PRIMARY_PROVIDER=moonshot
# MOONSHOT_MODEL_FAST=kimi-k2.5
# MOONSHOT_MODEL_SMART=kimi-k2.6

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=*

# Gmail Integration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-backend-url.com/api/gmail/callback
FRONTEND_URL=https://your-frontend-url.com

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_URL=https://your-backend-url.com/api/telegram/webhook

# Encryption (for OAuth tokens)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# Scheduled Jobs
ENABLE_JOBS=true

# Slack Integration
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_REDIRECT_URI=https://your-backend-url.com/api/slack/callback
